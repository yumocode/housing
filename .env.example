# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_key_here

# Twilio (get from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
MY_PHONE_NUMBER=+1xxxxxxxxxx

# Scraper tuning (optional — these are the defaults)
SCORE_THRESHOLD=7
MAX_PRICE=1000
FETCH_INTERVAL_MINUTES=10
MAX_LLM_CALLS_PER_RUN=25
MAX_LLM_CALLS_PER_DAY=150   # hard stop — prevents runaway costs from bugs

# Paths (optional)
DB_PATH=sf_rent_scraper.db
LOG_FILE=sf_rent_scraper.log
